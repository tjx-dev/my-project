#类方法和静态方法
#类方法@classmethod--必须使用装饰器，第一个表示类对象
class Student():
    school='黑马'
    @classmethod
    def show1(cls):
        print(f"cls:{cls}")
        print('类方法')
    @staticmethod
    def show2():
        print('静态方法')
if __name__=='__main__':
    a=Student()
    a.show1()
    print('-'*23)
    a.show2()
#静态方法@staticmethod

